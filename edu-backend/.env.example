###############################################################################
# Learnova Backend environment template
# Copy to .env for local development.
###############################################################################

# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=edu_platform

# DB startup retry behavior
DB_CONNECT_RETRIES=10
DB_RETRY_DELAY_MS=2000
DB_CONNECT_TIMEOUT_MS=10000
DB_POOL_CONNECTION_LIMIT=10

# Optional dev bootstrap tuning (used by npm run dev script)
# XAMPP_MYSQL_START_BAT=D:\xampp\mysql_start.bat
# DB_BOOT_RETRIES=45
# DB_BOOT_RETRY_DELAY_MS=1000

# CORS allowlist
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Session + cookie
SESSION_COOKIE_NAME=edu.sid
SESSION_SECRET=replace-with-a-strong-random-secret
SESSION_SAMESITE=lax
SESSION_SECURE=false
SESSION_MAX_AGE_MS=86400000
SESSION_STORE=memory
# SESSION_STORE_TABLE=session_store

# Optional cookie domain for real domains only
# COOKIE_DOMAIN=.learnova.com

# Optional email transport
# Required in production (validated at startup)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=user@example.com
# EMAIL_PASS=replace-with-real-secret
# EMAIL_FROM=

# Optional observability
# LOG_LEVEL=info

# Auth abuse protection (rate limits)
AUTH_LOGIN_RATE_WINDOW_MS=900000
AUTH_LOGIN_RATE_MAX=10
AUTH_REQUEST_RESET_RATE_WINDOW_MS=900000
AUTH_REQUEST_RESET_RATE_MAX=5
AUTH_VERIFY_RESET_RATE_WINDOW_MS=900000
AUTH_VERIFY_RESET_RATE_MAX=10
AUTH_REGISTER_RATE_WINDOW_MS=3600000
AUTH_REGISTER_RATE_MAX=20

###############################################################################
# Production notes:
# - Set NODE_ENV=production
# - Use SESSION_STORE=mysql
# - Set SESSION_STORE_TABLE=session_store (or your custom table)
# - Set SESSION_SECURE=true
# - Set a strong SESSION_SECRET
# - Set FRONTEND_ORIGINS to real HTTPS origins
###############################################################################
